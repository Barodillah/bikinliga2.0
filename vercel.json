{
    "functions": {
        "api/index.js": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/t/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/c/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/post/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ]
}